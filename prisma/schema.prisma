generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// === AUTH (NextAuth.js) ===
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  username      String?   @unique
  image         String?
  bio           String?
  signature     String?   @db.Text
  location      String?
  passwordHash  String?
  role          Role      @default(MEMBER)
  // Denormalized counters, updated on post create/delete for fast profile render
  postCount     Int       @default(0)
  // Structured "current stack" — GolfWRX "What's in the bag" equivalent.
  // Array of { compound, dose, frequency, route, notes }
  stackJson     Json?
  createdAt     DateTime  @default(now())

  accounts      Account[]
  sessions      Session[]
  threads       Thread[]
  replies       Reply[]
  votes         Vote[]
  reactions     Reaction[]
  subscriptions ThreadSubscription[]
  protocols     SavedProtocol[]
  bookmarks     Bookmark[]
  logs          JournalEntry[]
  reportsFiled    Report[] @relation("ReportReporter")
  reportsResolved Report[] @relation("ReportResolver")
  pollVotes       PollVote[]
  lastReplyOn   Thread[] @relation("ThreadLastReplyAuthor")
}

enum Role {
  MEMBER
  MODERATOR
  ADMIN
}

// === FORUM ===
model ForumCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String
  sortOrder   Int      @default(0)
  // Self-reference for sub-forums (null = top-level)
  parentId    String?
  parent      ForumCategory?  @relation("SubForums", fields: [parentId], references: [id])
  children    ForumCategory[] @relation("SubForums")
  threads     Thread[]

  @@index([parentId, sortOrder])
}

model Thread {
  id         String   @id @default(cuid())
  title      String
  slug       String
  body       String   @db.Text
  isPinned   Boolean  @default(false)
  isLocked   Boolean  @default(false)
  views      Int      @default(0)
  replyCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Denormalized last-reply info — huge perf win for thread lists
  lastReplyAt       DateTime?
  lastReplyAuthor   User?    @relation("ThreadLastReplyAuthor", fields: [lastReplyAuthorId], references: [id])
  lastReplyAuthorId String?

  author        User          @relation(fields: [authorId], references: [id])
  authorId      String
  category      ForumCategory @relation(fields: [categoryId], references: [id])
  categoryId    String
  replies       Reply[]
  votes         Vote[]
  reactions     Reaction[]
  subscriptions ThreadSubscription[]
  tags          Tag[]
  reports       Report[]
  poll          Poll?

  @@unique([categoryId, slug])
  @@index([categoryId, isPinned(sort: Desc), lastReplyAt(sort: Desc)])
  @@index([authorId])
}

// === POLLS (one optional poll per thread) ===
model Poll {
  id             String       @id @default(cuid())
  question       String
  multipleChoice Boolean      @default(false)
  closesAt       DateTime?
  createdAt      DateTime     @default(now())

  thread         Thread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  threadId       String       @unique

  options        PollOption[]
  votes          PollVote[]
}

model PollOption {
  id        String     @id @default(cuid())
  label     String
  sortOrder Int        @default(0)

  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  pollId    String
  votes     PollVote[]

  @@index([pollId, sortOrder])
}

model PollVote {
  id        String     @id @default(cuid())
  createdAt DateTime   @default(now())

  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  pollId    String
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  optionId  String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String

  // One vote per option per user — allows multi-select without dup checks
  @@unique([userId, optionId])
  @@index([pollId])
}

model Reply {
  id        String    @id @default(cuid())
  body      String    @db.Text
  editedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  author    User       @relation(fields: [authorId], references: [id])
  authorId  String
  thread    Thread     @relation(fields: [threadId], references: [id], onDelete: Cascade)
  threadId  String
  parent    Reply?     @relation("ReplyTree", fields: [parentId], references: [id])
  parentId  String?
  children  Reply[]    @relation("ReplyTree")
  votes     Vote[]
  reactions Reaction[]
  reports   Report[]

  @@index([threadId, createdAt])
  @@index([authorId])
}

// === REACTIONS (GolfWRX-style: Like, Agree, Useful, Funny, etc.) ===
enum ReactionType {
  LIKE
  AGREE
  USEFUL
  FUNNY
  THANKS
}

model Reaction {
  id        String       @id @default(cuid())
  type      ReactionType
  createdAt DateTime     @default(now())

  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  thread    Thread? @relation(fields: [threadId], references: [id], onDelete: Cascade)
  threadId  String?
  reply     Reply?  @relation(fields: [replyId], references: [id], onDelete: Cascade)
  replyId   String?

  // One reaction-type per user per target
  @@unique([userId, threadId, type])
  @@unique([userId, replyId, type])
  @@index([threadId])
  @@index([replyId])
}

// === REPORTS (user-flagged content → mod queue) ===
enum ReportStatus {
  OPEN
  RESOLVED
  DISMISSED
}

model Report {
  id        String       @id @default(cuid())
  createdAt DateTime     @default(now())
  resolvedAt DateTime?
  status    ReportStatus @default(OPEN)
  reason    String       @db.Text

  reporter   User   @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reporterId String

  resolver   User?   @relation("ReportResolver", fields: [resolverId], references: [id])
  resolverId String?

  // The flagged content — exactly one of threadId or replyId is set
  thread   Thread? @relation(fields: [threadId], references: [id], onDelete: Cascade)
  threadId String?
  reply    Reply?  @relation(fields: [replyId], references: [id], onDelete: Cascade)
  replyId  String?

  @@index([status, createdAt])
  @@index([threadId])
  @@index([replyId])
}

// === THREAD SUBSCRIPTIONS (follow a thread for notifications) ===
model ThreadSubscription {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  thread   Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  threadId String

  @@unique([userId, threadId])
  @@index([threadId])
}

model Vote {
  id       String  @id @default(cuid())
  value    Int // +1 or -1
  user     User    @relation(fields: [userId], references: [id])
  userId   String
  thread   Thread? @relation(fields: [threadId], references: [id], onDelete: Cascade)
  threadId String?
  reply    Reply?  @relation(fields: [replyId], references: [id], onDelete: Cascade)
  replyId  String?

  @@unique([userId, threadId])
  @@unique([userId, replyId])
}

model Tag {
  id      String   @id @default(cuid())
  name    String   @unique
  slug    String   @unique
  threads Thread[]
}

// === TOOLS / USER DATA ===
model SavedProtocol {
  id        String   @id @default(cuid())
  name      String
  data      Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  userId    String

  @@index([userId])
}

model JournalEntry {
  id        String   @id @default(cuid())
  title     String
  body      String   @db.Text
  date      DateTime
  tags      String[]
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  userId    String

  @@index([userId, date(sort: Desc)])
}

model Bookmark {
  id        String   @id @default(cuid())
  type      String // "thread" | "article" | "protocol"
  targetId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  userId    String

  @@unique([userId, type, targetId])
  @@index([userId])
}

// === TWEET DRAFTING + SCHEDULING (@pepatlas automation) ===
enum TweetStatus {
  PENDING    // generated, awaiting admin approval
  APPROVED   // approved but not yet posted (scheduled)
  POSTED     // successfully posted to X
  REJECTED   // admin rejected; skip
  FAILED     // tried to post but X API errored
}

model TweetDraft {
  id           String      @id @default(cuid())
  body         String      @db.Text
  status       TweetStatus @default(PENDING)
  sourceType   String?     // "thread" | "article" | "stat" | "manual"
  sourceId     String?     // threadId / article slug / etc
  generatedAt  DateTime    @default(now())
  postedAt     DateTime?
  scheduledFor DateTime?
  tweetId      String?     // X's tweet ID if posted
  tweetUrl     String?
  errorMessage String?

  @@index([status, generatedAt(sort: Desc)])
}

// === NEWSLETTER SUBSCRIBERS ===
model NewsletterSubscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  createdAt      DateTime  @default(now())
  verifiedAt     DateTime?
  unsubscribedAt DateTime?
  verifyToken    String    @unique
  source         String?   // "footer" | "thread" | "article" | etc

  @@index([verifiedAt])
}

// === ARTICLES ===
model Article {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  body        String    @db.Text
  summary     String
  coverImage  String?
  tags        String[]
  status      String    @default("draft") // draft | published
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  authorId    String

  @@index([status, publishedAt(sort: Desc)])
}
